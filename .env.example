# NextAuth — required
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# Google OAuth — required for sign-in and Drive picker
# Get from https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated allow-list of emails that may sign in.
# Defaults to summers.blake@gmail.com if unset.
AUTH_ALLOWED_EMAILS=summers.blake@gmail.com

# Optional: only needed when not auto-detected (Vercel sets it).
# AUTH_URL=http://localhost:3000

# Google Cloud Text-to-Speech (recommended for natural voice)
# https://console.cloud.google.com/apis/credentials -> API key restricted to
# Cloud Text-to-Speech API. Without it, the app falls back to browser SpeechSynthesis.
GOOGLE_TTS_API_KEY=
